	cd /workspace/build_verify && $(MAKE) $(MAKESILENT) -f library/CMakeFiles/meshmonk_lib.dir/build.make library/CMakeFiles/meshmonk_lib.dir/src/meshmonk.cpp.s
.PHONY : src/meshmonk.cpp.s

